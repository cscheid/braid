{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "braid-viewer",
  "identifier": "org.cscheid.braidviewer",
  "build": {
    "beforeDevCommand": {
      "script": "npm run dev",
      "cwd": "../../ui"
    },
    "beforeBuildCommand": {
      "script": "npm run build",
      "cwd": "../../ui"
    },
    "frontendDist": "../../ui/dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'wasm-unsafe-eval'; connect-src 'self' ipc: http://ipc.localhost wss://sync.automerge.org; img-src 'self' data: asset: https://asset.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
